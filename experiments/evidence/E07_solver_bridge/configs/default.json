{
  "experiment_name": "exp07-pypeec-solver-cross-validation",
  "random_seed": 20260429,
  "units": "SI",
  "sensor_grid": {
    "n": 17,
    "fov_m": 0.0012,
    "z_m": 8e-05
  },
  "currents": {
    "default_current_a": 0.001
  },
  "geometry": {
    "layer_gap_m": 5e-05,
    "default_trace_width_m": 4e-05,
    "default_trace_thickness_m": 1e-05,
    "default_via_radius_m": 2e-05,
    "default_segment_subdivisions": 12,
    "finite_width_filaments": {
      "n_width": 3,
      "n_thickness": 1
    }
  },
  "pypeec": {
    "backend": "real_pypeec_api",
    "minimum_version": "5.8.0",
    "cross_section_fill": true,
    "voxel_pitch_xy_m": 6e-05,
    "voxel_pitch_z_m": 2.5e-05,
    "n_xy": 17,
    "n_z": 7,
    "raster_step_fraction": 0.45,
    "rho_re_ohm_m": 1.72e-08,
    "source_admittance_s": 0.0,
    "sink_impedance_ohm": 1e-06,
    "solver": {
      "fft_library": "SciPy",
      "integral_simplify": 20.0,
      "direct_rel_tol": 1e-06,
      "direct_n_inner": 10,
      "direct_n_outer": 10,
      "power_n_min": 2,
      "power_n_cmp": 2
    },
    "convergence_sweep": {
      "enabled": true,
      "cases": [
        "straight_trace",
        "via_pair",
        "two_layer_route_with_via",
        "dense_via_background",
        "no_via_background"
      ],
      "levels": [
        {
          "label": "coarse",
          "voxel_pitch_xy_m": 6e-05,
          "voxel_pitch_z_m": 2.5e-05,
          "n_xy": 17,
          "n_z": 7
        },
        {
          "label": "medium",
          "voxel_pitch_xy_m": 4e-05,
          "voxel_pitch_z_m": 2.5e-05,
          "n_xy": 25,
          "n_z": 7
        },
        {
          "label": "fine",
          "voxel_pitch_xy_m": 3e-05,
          "voxel_pitch_z_m": 2.5e-05,
          "n_xy": 33,
          "n_z": 7
        },
        {
          "label": "ultrafine",
          "voxel_pitch_xy_m": 2e-05,
          "voxel_pitch_z_m": 2.5e-05,
          "n_xy": 49,
          "n_z": 7
        }
      ]
    },
    "notes": "No proxy fallback is allowed. exp07 must execute pypeec.run_mesher_data and pypeec.run_solver_data."
  },
  "exp03_like_subset": {
    "enabled": true,
    "cases": [
      "two_layer_route_with_via",
      "multi_via_route",
      "dense_via_background",
      "no_via_background",
      "bend_artifact_trace"
    ],
    "notes": "Small connected Manhattan cases and deterministic variants that mirror exp03 route families before PyPEEC fields are routed into exp04/exp06."
  },
  "pypeec_distribution_targets": {
    "enabled": true,
    "target_cases_per_hypothesis": {
      "H0_sheet_only": 100,
      "H1_sheet_via": 100,
      "H2_sheet_return": 100,
      "H3_sheet_artifact": 100
    },
    "base_cases_by_hypothesis": {
      "H0_sheet_only": [
        "no_via_background"
      ],
      "H1_sheet_via": [
        "two_layer_route_with_via",
        "multi_via_route",
        "dense_via_background"
      ],
      "H2_sheet_return": [
