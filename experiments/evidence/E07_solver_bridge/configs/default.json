      ],
      "H3_sheet_artifact": [
        "bend_artifact_trace"
      ]
    },
    "max_variant_index": 220,
    "notes": "Deterministically expands the real PyPEEC mini distribution before solving so exp08 receives at least 100 bridge cases for each H0/H1/H2/H3 hypothesis class."
