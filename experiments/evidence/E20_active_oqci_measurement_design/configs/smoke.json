    "ridge_alpha": 0.08
  },
  "adversarial_pair_count": 1,
  "candidate_pool": [
    {"id": "add_h1.6_Bxyz",     "height_um": 1.6,  "components": ["Bx", "By", "Bz"], "description": "Additional 1.6um full Bxyz",   "cost": 1.0},
    {"id": "add_h6.4_Bz",       "height_um": 6.4,  "components": ["Bz"],             "description": "Additional 6.4um Bz only",    "cost": 0.4},
    {"id": "add_state2_Bz",     "height_um": 0.0,  "components": ["Bx", "By", "Bz"], "description": "Multi-state (2) baseline Bz", "cost": 0.8, "n_states": 2},
    {"id": "add_state4_Bxyz",   "height_um": 0.0,  "components": ["Bx", "By", "Bz"], "description": "Multi-state (4) baseline Bxyz", "cost": 1.5, "n_states": 4},
    {"id": "add_h1.6_state2_Bz", "height_um": 1.6, "components": ["Bz"],             "description": "1.6um Bz + 2-state excitation", "cost": 1.0, "n_states": 2}
  ],
  "utility_weights": {
    "interval_width": 1.0,
    "near_null": 1.0,
    "pairwise_distance": 0.5,
    "wrong_accept": 2.0,
    "cost": 0.1
  }
