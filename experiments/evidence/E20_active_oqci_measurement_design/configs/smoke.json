{
  "schema_version": "e20-active-oqci-config-v2",
  "random_seed": 20010,
  "grid_size": 6,
  "layer_count": 4,
  "pixel_pitch_um": 1.0,
  "layer_spacing_um": 1.2,
  "sensor_height_um": 3.2,
  "sensor_heights_um": [3.2],
  "noise_sigma": 0.018,
  "case_count_per_family": 1,
  "families": [
